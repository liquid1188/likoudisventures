# Likoudis Ventures — Environment Variables
# Copy to .env.local for local development.

# Resend API key (NEW Resend account, separate from the Foundation's)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend Audience ID for "The Branch" newsletter subscribers
RESEND_AUDIENCE_ID=

# The verified sender domain — must be verified in Resend
RESEND_FROM_EMAIL=hello@likoudisventures.com

# Where inquiry form submissions are routed
INQUIRY_TO_EMAIL=hello@likoudisventures.com

# Newsletter "from" line (display name)
NEWSLETTER_FROM_NAME=Likoudis Ventures

# Admin password for /admin/branch compose page
ADMIN_PASSWORD=change-this-to-something-secure

# Public site URL
NEXT_PUBLIC_SITE_URL=https://likoudisventures.com
